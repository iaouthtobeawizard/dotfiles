@import 'colors/gruvbox-material.css';

* {
    all: unset;
    font-family: "Iosevka Nerd Font Propo", monospace;
}

window#waybar {
    background-color: @bg0;
    color: @fg;
    border-radius: 0 0 12px 12px;
}

#workspaces {
    min-width: 100px;
    font-size: 0.4rem;
    padding: 2px 4px;
    margin: 11px 0;
    border-radius: 99px;
}

#workspaces button {
    background-color: @bg4;
    color: transparent;
    padding: 0 5px;
    border-radius: 99px;
    margin: 0 2px;
    min-width: 4px;
}

#workspaces button.active {
    background-color: @blue;
    min-width: 1.4rem;
    transition: all 200ms ease-in-out;
}

#clock#left,
#clock#right {
    margin: 0 15px;
    font-weight: 700;
    font-size: 1.12rem;
}

.modules-left {
    margin-left: 12px;
}

.modules-right {
    margin-right: 12px;
}

#mpris {
    margin: 0 12px;
    font-size: 0.9rem;
    letter-spacing: 1px;
    font-weight: 700;
}


#battery {
    margin: 24px;
}


#taskbar button {
    background-color: @bg4;
    color: transparent;
    padding: 0 15px;
    border-radius: 99px;
    margin: 5px 2px;
    min-width: 4px;
}

#taskbar button.active {
    background-color: @blue;
    min-width: 1.4rem;
    transition: all 200ms ease-in-out;
}
